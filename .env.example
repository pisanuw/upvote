# UpvoteMe environment variables
# Copy this file to .env for local development and to Netlify site environment variables for production.
# Keep real secrets only in .env and Netlify, never in git.

# Required: Supabase Postgres connection string.
# Source: Supabase dashboard -> Project Settings -> Database -> Connection string (URI form).
# Keep URL-encoding for special password characters (for example +, /, *, &, @).
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_URLENCODED_DB_PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"

# Required: Supabase project URL.
# Example: https://your-project-ref.supabase.co
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"

# Required for attachment upload/download APIs.
# Source: Supabase dashboard -> Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY="[YOUR_SUPABASE_SERVICE_ROLE_KEY]"

# Required: private storage bucket name used for comment attachments.
# Use a unique name that won't collide with URL path segments.
SUPABASE_STORAGE_BUCKET=""

# Required: random secret for NextAuth session and token signing.
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-long-random-secret"

# Required in production: public app URL (no trailing slash).
# Local example: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth provider.
# If unused, leave empty.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: Magic-link SMTP provider.
# If unused, leave host/user/pass empty.
AUTH_SMTP_HOST=""
AUTH_SMTP_PORT="587"
AUTH_SMTP_USER=""
AUTH_SMTP_PASS=""
AUTH_SMTP_FROM=""

# Required if using /api/cron/cleanup endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-with-another-random-secret"
